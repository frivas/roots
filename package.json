{
  "name": "roots",
  "version": "0.2.0",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/frivas/roots.git"
  },
  "bugs": {
    "url": "https://github.com/frivas/roots/issues"
  },
  "homepage": "https://github.com/frivas/roots#readme",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build": "npm run build:frontend && npm run build:backend",
    "lint": "concurrently \"cd frontend && npm run lint\" \"cd backend && npm run lint\"",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm run test",
    "test:backend": "cd backend && npm run test",
    "test:e2e": "cd frontend && npm run test:e2e",
    "test:coverage": "npm run test:frontend -- --coverage && npm run test:backend -- --coverage",
    "report:portfolio-coverage": "bash scripts/report-portfolio-coverage.sh",
    "check-localization": "node scripts/check-localization.js",
    "pre-commit": "npm run check-localization && npm run lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "next": "16.2.4"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-x64": "^4.57.1"
  },
  "overrides": {
    "fast-xml-parser": "5.5.9",
    "next": "16.2.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "diff": "8.0.4",
    "yaml": "2.8.3",
    "tmp": "0.2.5",
    "lodash": "4.18.1",
    "smol-toml": "1.6.1",
    "minimatch": "10.2.5",
    "@vercel/node": {
      "undici": "6.24.1",
      "path-to-regexp": "6.3.0"
    },
    "@vercel/static-config": {
      "ajv": "8.18.0"
    },
    "@clerk/clerk-react": {
      "@clerk/shared": "3.47.4"
    },
    "@lingo.dev/_react": {
      "next": "15.5.15",
      "lodash": "4.18.1"
    },
    "lingo.dev": {
      "@modelcontextprotocol/sdk": "1.29.0",
      "diff": "8.0.4",
      "yaml": "2.8.3"
    }
  }
}
