{
  "ignore": ["eslint.config.js"],
  "ignoreBinaries": ["du", "knip", "license-checker", "AGPL-3.0", "playwright"],
  "workspaces": {
    "frontend": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["src/test/**"],
      "ignoreDependencies": [
        "@eslint/js",
        "eslint-plugin-react-hooks",
        "eslint-plugin-react-refresh",
        "globals",
        "typescript-eslint",
        "@testing-library/user-event"
      ]
    },
    "backend": {
      "entry": ["src/index.ts", "api/serverless.ts", "api/health.ts", "api/webhook-test.ts"],
      "project": ["src/**/*.ts", "api/**/*.ts"],
      "ignore": ["src/test/**"],
      "ignoreDependencies": [
        "tsx",
        "@eslint/js",
        "globals"
      ]
    }
  }
}
